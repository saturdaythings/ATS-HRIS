// V.Two Ops - Optimized Prisma Schema
// ATS + Onboarding/Offboarding + Device Inventory
// Optimized for: accuracy, token efficiency, query performance, security, simplicity
// Generated: 2026-03-24

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTH & SETTINGS
// ============================================================================

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   // Hashed with bcrypt
  role      String   @default("viewer") // admin, viewer
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model Settings {
  id        String   @id @default(cuid())
  userId    String   @unique
  theme     String   @default("light") // light, dark
  pageSize  Int      @default(25)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// CONFIGURATION LISTS (Dropdowns & Tags)
// ============================================================================

model ConfigList {
  id          String            @id @default(cuid())
  name        String            @unique // candidate_source, seniority, skill_tags, rejection_reason, interview_format
  description String?
  items       ConfigListItem[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([name])
}

model ConfigListItem {
  id        String     @id @default(cuid())
  listId    String
  list      ConfigList @relation(fields: [listId], references: [id], onDelete: Cascade)
  label     String     // Display value
  value     String     // Stored value (optional, defaults to label)
  order     Int        @default(0)
  createdAt DateTime   @default(now())

  // Foreign key references
  candidateSources  Candidate[]     @relation("CandidateSource")
  candidateSeniorities Candidate[]  @relation("CandidateSeniority")
  rejectionReasons  Candidate[]     @relation("RejectionReason")
  interviewFormats  Interview[]     @relation("InterviewFormat")
  skillTags         CandidateSkillTag[]

  @@unique([listId, value])
  @@index([listId, order])
}

// ============================================================================
// CLIENTS (Lightweight - name, contact, notes)
// ============================================================================

model Client {
  id             String   @id @default(cuid())
  name           String   @unique
  primaryContact String?
  email          String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  candidates     Candidate[]
  employees      Employee[]
  trackTemplates TrackTemplate[]

  @@index([name])
}

// ============================================================================
// ATS: CANDIDATES & SUPPORTING MODELS
// ============================================================================

model Candidate {
  id                String   @id @default(cuid())

  // Core info
  name              String
  email             String   @unique
  phone             String?
  location          String?  // city, state — free text
  roleApplied       String

  // Pipeline
  status            String   @default("active") // active, hired, rejected, withdrawn
  stage             String   @default("applied") // applied, screening, interview, offer, closed

  // Classifications
  sourceId          String?
  source            ConfigListItem? @relation("CandidateSource", fields: [sourceId], references: [id], onDelete: SetNull)
  referredBy        String?  // Free text if source = referral

  seniorityId       String?
  seniority         ConfigListItem? @relation("CandidateSeniority", fields: [seniorityId], references: [id], onDelete: SetNull)

  clientId          String?
  client            Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  rejectionReasonId String?
  rejectionReason   ConfigListItem? @relation("RejectionReason", fields: [rejectionReasonId], references: [id], onDelete: SetNull)

  notes             String?
  sourcedAt         DateTime @default(now()) // Overridable

  // Denormalized fields (for performance)
  latestInterviewAt DateTime? // Latest interview.scheduledAt, updated on interview create
  latestStageChangeAt DateTime? // Updated whenever stage changes, enables 14-day stale check

  // Relationships
  resumes           Resume[]
  interviews        Interview[]
  offers            Offer[]
  skillTags         CandidateSkillTag[]
  employee          Employee? @relation("CandidateToEmployee")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([stage])
  @@index([sourceId])
  @@index([seniorityId])
  @@index([clientId])
  @@index([latestStageChangeAt]) // For stale detection
  @@index([createdAt])
}

model Resume {
  id          String   @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  fileUrl     String   // Drive/SharePoint link
  fileName    String
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  uploadedAt  DateTime @default(now())

  createdAt   DateTime @default(now())

  @@index([candidateId, isActive])
  @@index([uploadedAt])
}

model CandidateSkillTag {
  id          String   @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  tagId       String
  tag         ConfigListItem @relation(fields: [tagId], references: [id], onDelete: Restrict)

  createdAt   DateTime @default(now())

  @@unique([candidateId, tagId])
  @@index([candidateId])
}

// ============================================================================
// ATS: INTERVIEWS
// ============================================================================

model Interview {
  id          String   @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  scheduledAt DateTime
  status      String   @default("scheduled") // scheduled, completed, cancelled

  formatId    String?
  format      ConfigListItem? @relation("InterviewFormat", fields: [formatId], references: [id], onDelete: SetNull)

  notes       String?

  interviewers Interviewer[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([candidateId, scheduledAt])
  @@index([status])
}

model Interviewer {
  id              String    @id @default(cuid())
  interviewId     String
  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  name            String
  role            String?   // e.g. "PM", "Tech Lead", "Client - Acme"
  isClient        Boolean   @default(false)
  clientName      String?   // Free text if isClient = true

  recommendation  String?   // hire, no_hire, maybe
  feedback        String?   // Open-ended notes
  sourceNotes     String?   // Referral context

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([interviewId])
}

// ============================================================================
// ATS: OFFERS
// ============================================================================

model Offer {
  id          String   @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  role        String
  compensation String? // Free text: salary, rate, range
  startDate   DateTime?

  sentAt      DateTime?
  expiresAt   DateTime?
  status      String   @default("pending") // pending, accepted, declined, expired

  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([candidateId, status])
  @@index([expiresAt])
}

// ============================================================================
// EMPLOYEES & ONBOARDING
// ============================================================================

model Employee {
  id          String   @id @default(cuid())

  name        String
  email       String   @unique
  title       String
  department  String?
  startDate   DateTime?
  status      String   @default("active") // active, offboarded

  candidateId String?  @unique
  candidate   Candidate? @relation("CandidateToEmployee", fields: [candidateId], references: [id], onDelete: Restrict)

  clientId    String?
  client      Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // Relationships
  assignments DeviceAssignment[]
  onboardingRuns OnboardingRun[]
  activities  Activity[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([department])
  @@index([startDate])
}

// ============================================================================
// ONBOARDING & OFFBOARDING (Track System)
// ============================================================================

model TrackTemplate {
  id          String         @id @default(cuid())

  name        String
  type        String         // company (auto-apply), role (suggested), client (optional)
  description String?

  clientId    String?        // Only for client-type tracks
  client      Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  autoApply   Boolean        @default(false) // Only true for company tracks

  tasks       TaskTemplate[]
  runs        OnboardingRun[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, type, clientId])
  @@index([type])
}

model TaskTemplate {
  id          String        @id @default(cuid())
  trackId     String
  track       TrackTemplate @relation(fields: [trackId], references: [id], onDelete: Cascade)

  name        String
  description String?

  ownerRole   String?       // "ops", "pm", "hiring_manager" — free text
  dueDaysOffset Int?        // Relative to startDate: negative = before, null = no deadline
  order       Int           @default(0)

  instances   TaskInstance[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([trackId, order])
}

model OnboardingRun {
  id          String   @id @default(cuid())

  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type        String   // onboarding, offboarding
  status      String   @default("pending") // pending, in_progress, complete
  startDate   DateTime @default(now())

  trackId     String
  track       TrackTemplate @relation(fields: [trackId], references: [id], onDelete: Restrict)

  tasks       TaskInstance[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([employeeId, status])
  @@index([trackId])
}

model TaskInstance {
  id              String        @id @default(cuid())

  runId           String
  run             OnboardingRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  taskTemplateId  String
  taskTemplate    TaskTemplate  @relation(fields: [taskTemplateId], references: [id], onDelete: Restrict)

  assignedTo      String?       // "ops", "pm", "hiring_manager", etc.

  dueDate         DateTime?     // Calculated from startDate + dueDaysOffset
  status          String        @default("pending") // pending, in_progress, complete, skipped
  notes           String?
  completedAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([runId, status, dueDate])
  @@index([dueDate]) // For "due in next 7 days" queries
}

// ============================================================================
// DEVICES & ASSIGNMENTS
// ============================================================================

model Device {
  id          String             @id @default(cuid())

  serial      String             @unique
  type        String             // laptop, monitor, phone, peripheral
  make        String
  model       String
  condition   String             @default("good") // new, good, fair, poor
  status      String             @default("available") // available, assigned, retired
  warrantyExp DateTime?
  notes       String?

  assignments DeviceAssignment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([type])
}

model DeviceAssignment {
  id           String    @id @default(cuid())

  deviceId     String
  device       Device    @relation(fields: [deviceId], references: [id], onDelete: Restrict)

  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  assignedDate DateTime  @default(now())
  returnedDate DateTime?
  condition    String?   // Condition when returned
  notes        String?

  createdAt    DateTime  @default(now())

  @@unique([deviceId, returnedDate]) // Only one active assignment per device
  @@index([employeeId, returnedDate]) // For "current devices" and "device history"
  @@index([deviceId, returnedDate])
}

// ============================================================================
// AUDIT & LOGGING (Optional, recommended)
// ============================================================================

model AuditLog {
  id        String   @id @default(cuid())

  entityType String  // "candidate", "offer", "interviewer"
  entityId  String

  action    String   // "created", "updated", "deleted"
  field     String   // Which field changed (null for full-record operations)
  oldValue  String?  // Previous value
  newValue  String?  // New value

  changedBy String?  // User ID

  createdAt DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([changedBy, createdAt])
}

// ============================================================================
// ACTIVITY FEED (Dashboard Timeline)
// ============================================================================

model Activity {
  id          String   @id @default(cuid())

  type        String   // hire, onboarding, device, task, promotion, offer, interview, rejection
  description String   // Human-readable description

  // Optional relationships
  employeeId  String?
  employee    Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  candidateId String?
  candidate   Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  deviceId    String?
  device      Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  offerId     String?
  offer       Offer? @relation(fields: [offerId], references: [id], onDelete: SetNull)

  metadata    String?  // JSON for additional context

  createdAt   DateTime @default(now())

  @@index([type, createdAt])
  @@index([employeeId, createdAt])
  @@index([candidateId, createdAt])
  @@index([deviceId, createdAt])
  @@index([createdAt])
}
