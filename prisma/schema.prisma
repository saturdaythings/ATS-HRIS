// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// People module
model Candidate {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String
  status    String   @default("active") // active, rejected, hired
  stage     String   @default("sourced") // sourced, screening, interview, offer, hired
  resumeUrl String?
  notes     String?
  employee  Employee? // 1:1 relationship after hire
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([stage])
}

model Employee {
  id              String   @id @default(cuid())
  candidateId     String?  @unique // FK to Candidate for history
  name            String
  email           String   @unique
  title           String
  department      String
  startDate       DateTime
  status          String   @default("active") // active, offboarded

  // Relationships
  onboardingTasks OnboardingTask[]
  offboardingTasks OffboardingTask[]
  assignments     Assignment[]
  activities      Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([department])
}

model OnboardingTask {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  task        String
  dueDate     DateTime
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([employeeId])
  @@index([completed])
}

model OffboardingTask {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  task        String
  dueDate     DateTime
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([employeeId])
  @@index([completed])
}

// Device module
model Device {
  id          String   @id @default(cuid())
  serial      String   @unique
  type        String   // laptop, desktop, monitor, phone, tablet, etc.
  make        String   // Apple, Dell, etc.
  model       String
  condition   String   @default("good") // good, fair, poor
  status      String   @default("available") // available, assigned, retired
  warrantyEnd DateTime?

  // Relationships
  assignments Assignment[]
  activities  Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
}

model Assignment {
  id            String   @id @default(cuid())
  deviceId      String
  device        Device   @relation(fields: [deviceId], references: [id], onDelete: Restrict)
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  assignedDate  DateTime @default(now())
  returnedDate  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Unique constraint: one active assignment per device
  @@unique([deviceId, returnedDate]) // Only one where returnedDate IS NULL
  @@index([employeeId])
  @@index([returnedDate])
}

// Ops shared
model Activity {
  id          String   @id @default(cuid())
  type        String   // hire, offboard, device_assign, device_return, task_complete, etc.
  description String

  // Polymorphic references
  employeeId  String?
  employee    Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  deviceId    String?
  device      Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@index([deviceId])
  @@index([type])
  @@index([createdAt])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("user") // user, admin (for phase 5+ auth)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id        String   @id @default(cuid())
  userId    String   @unique
  theme     String   @default("light")
  pageSize  Int      @default(25)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
