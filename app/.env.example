# Frontend Environment Configuration
# Copy this file to .env.local and customize for your environment

# ===========================
# API Configuration
# ===========================
# Development: Leave blank or use /api (Vite proxy)
# Production: Set to your deployed backend URL
#   Examples:
#   - https://vtwo-ops-api.railway.app
#   - https://vtwo-ops-api.onrender.com
#   - http://localhost:3001 (for local testing)
VITE_API_URL=

# ===========================
# Feature Flags (Optional)
# ===========================
# VITE_DEBUG_MODE=false
